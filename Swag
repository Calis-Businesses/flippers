<link rel="stylesheet" href="style.css">
<style>
  .swag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 18px;
    margin-bottom: 32px;
  }
  .swag-card {
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(120,30,70,.06);
    display: flex;
    flex-direction: column;
    transition: transform .2s cubic-bezier(.16,1,.3,1), box-shadow .2s;
  }
  .swag-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 20px rgba(120,30,70,.12);
  }
  .swag-img {
    background: var(--offwhite);
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3.2rem;
    position: relative;
  }
  .swag-badge {
    position: absolute;
    top: 10px; right: 10px;
    background: var(--yellow);
    color: var(--ink);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .5px;
    padding: 3px 9px;
    border-radius: 999px;
    font-family: 'Fredoka', sans-serif;
  }
  .swag-body {
    padding: 14px 16px 18px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .swag-body h3 {
    font-family: 'Fredoka', sans-serif;
    font-size: 16px;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .swag-body p {
    font-size: 13px;
    color: #6b6469;
    line-height: 1.45;
    flex: 1;
    margin-bottom: 10px;
  }
  .swag-price {
    font-family: 'Fredoka', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--pinkdeep);
  }
  .swag-section-title {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    color: var(--pinkdeep);
    font-size: 22px;
    border-bottom: 3px solid var(--yellow);
    padding-bottom: 6px;
    margin-bottom: 18px;
  }
  .order-cta {
    background: var(--offwhite);
    border: 2px solid var(--pinkdeep);
    border-radius: 12px;
    padding: 28px 24px;
    text-align: center;
    margin-bottom: 32px;
  }
  .order-cta h2 {
    font-family: 'Fredoka', sans-serif;
    color: var(--pinkdeep);
    font-size: 22px;
    margin-bottom: 8px;
  }
  .order-cta p {
    color: #3a343a;
    font-size: 15px;
    margin-bottom: 16px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  @media (max-width: 500px) {
    .swag-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .swag-img { height: 120px; font-size: 2.4rem; }
  }
</style>
</head>
